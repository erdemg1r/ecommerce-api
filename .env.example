PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce
JWT_ACCESS_SECRET=change-this-access-secret-to-a-random-string-with-at-least-128-characters-before-running-the-api-locally-or-in-class-1234567890abcdef
JWT_REFRESH_SECRET=change-this-refresh-secret-to-a-random-string-with-at-least-128-characters-before-running-the-api-locally-or-in-class-1234567890abcdef
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
